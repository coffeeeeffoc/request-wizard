{
  "manifest_version": 3,
  "name": "Request Wizard",
  "version": "1.0.0",
  "description": "Advanced HTTP request/response modifier with flexible rule groups, regex & JS function matching, header & body rewriting.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webRequest",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "tabs",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-isolated.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ]
}
